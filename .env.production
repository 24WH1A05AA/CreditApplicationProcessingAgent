# =========================================================================
# TechVest Credit Application Processing Agent - Production Config Template
# Copy this file to '.env' inside your production environment.
# =========================================================================

# Application Config
APP_NAME=CreditApplicationProcessingAgent
ENV=production
DEBUG=false
PORT=8000
HOST=0.0.0.0

# Database Settings
# Set this to a PostgreSQL connection URL in production, e.g.:
# DATABASE_URL=postgresql://user:password@db_host:5432/dbname
DATABASE_URL=sqlite:///./data/credit_processing.db

# Security Cryptography
# CHANGE THIS TO A SECURE, RANDOM 32-CHARACTER STRING IN PRODUCTION:
SECRET_KEY=prod_super_secure_secret_key_change_me_9988
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM Orchestration & RAG Configuration
# Provide a valid OpenAI API Key (starting with sk-) to enable RAG vector database indexing
OPENAI_API_KEY=mock-key-for-development
OPENAI_MODEL=gpt-4o

# Storage Paths
CHROMA_DB_PATH=./data/chromadb
KNOWLEDGE_BASE_DIR=./knowledge_base

# Logging
LOG_LEVEL=INFO

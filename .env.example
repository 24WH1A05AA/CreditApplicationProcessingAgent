# App Configuration
APP_NAME=CreditApplicationProcessingAgent
ENV=development
DEBUG=true
PORT=8000
HOST=0.0.0.0

# Security Configuration
SECRET_KEY=supersecretjwtkeyforcreditprocessingagentapplication
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/credit_processing

# LLM & OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o  # Fallback to GPT-4o if GPT-5.5 is not available

# RAG & Chroma Configuration
CHROMA_DB_PATH=./data/chromadb
KNOWLEDGE_BASE_DIR=./knowledge_base

# Logging
LOG_LEVEL=INFO

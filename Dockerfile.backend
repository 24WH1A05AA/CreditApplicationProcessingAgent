FROM python:3.11-slim

# Install system dependencies, including compilation tools and Tesseract OCR
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    python3-dev \
    libpq-dev \
    tesseract-ocr \
    tesseract-ocr-eng \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Enable headless compilation for hnswlib (used by ChromaDB)
ENV HNSWLIB_NO_NATIVE=1

# Copy dependency definition and install python libraries
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir -r requirements.txt

# Copy backend files and application code
COPY backend/ /app/backend/
COPY knowledge_base/ /app/knowledge_base/

# Create folders for uploads, database, and logs/traces
RUN mkdir -p /app/uploads /app/data /app/data/chromadb /app/data/debug_traces

EXPOSE 8000

ENV PYTHONUNBUFFERED=1
ENV PORT=8000
ENV HOST=0.0.0.0

# Start backend using uvicorn
CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
